{
  "id": "hpm.propagation.hybrid_scene",
  "name": "混合场景传播后端",
  "version": "2.0.0",
  "category": "propagation_backend",
  "layer": "Physics Layer",
  "summary": "把自由空间直达、一阶镜像反射和孔缝-腔体降阶模型作为可注册传播后端暴露给平台。",
  "provider": "HPM-DT 内置",
  "entry_point": {
    "kind": "builtin_hook",
    "target": "field_backend_summary"
  },
  "parameters_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "backend_id": {
        "type": "string",
        "default": "hybrid_scene",
        "enum": ["free_space_green", "image_ray", "aperture_cavity_rom", "hybrid_scene"],
        "description": "要审计或绑定的传播后端标识。"
      }
    }
  },
  "dependencies": ["hpm_platform.physics.field_backends"],
  "enabled_by_default": true,
  "safety": {
    "execution": "builtin_hook_only",
    "scope": "归一化标量复场与波长尺度几何",
    "blocked_outputs": ["绝对源功率", "真实作用距离", "器件毁伤阈值"]
  },
  "acceptance_tests": [
    "manifest 可解析",
    "入口点在 builtin_hook 白名单内",
    "可列出已注册传播后端"
  ],
  "sample_project": "configs/cae_project_v14.yaml",
  "tags": ["传播", "物理建模", "V2.0C"],
  "settings": {
    "backend_id": "hybrid_scene"
  }
}
