{
  "id": "hpm.publication.paper_template_pack",
  "name": "论文多模板包",
  "version": "2.0.0",
  "category": "report_template",
  "layer": "Publication Layer",
  "summary": "把 IEEE 会议、中文期刊和学位论文章节模板作为插件声明暴露给 Paper Factory。",
  "provider": "HPM-DT 内置",
  "entry_point": {
    "kind": "builtin_hook",
    "target": "report_template_summary"
  },
  "parameters_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "format": {
        "type": "string",
        "default": "paper_template",
        "enum": ["paper_template", "html", "latex", "zip"],
        "description": "要审计的报告或论文模板输出格式。"
      }
    }
  },
  "dependencies": ["hpm_platform.publication.paper_factory"],
  "enabled_by_default": true,
  "safety": {
    "execution": "builtin_hook_only",
    "scope": "论文模板结构、引用入口和补充材料索引",
    "blocked_outputs": ["真实毁伤概率", "真实作用距离", "真实器件阈值", "作战效能结论"]
  },
  "acceptance_tests": [
    "manifest 可解析",
    "模板声明可由 Paper Factory 合并",
    "模板结构审计可生成"
  ],
  "sample_project": "outputs_v20a_vv/paper_factory_v20d/templates",
  "tags": ["论文生产", "模板", "Paper Factory", "V2.0D"],
  "settings": {
    "default_format": "paper_template",
    "paper_templates": [
      {
        "id": "plugin_ieee_access",
        "name": "IEEE Access 扩展论文模板",
        "kind": "journal_article",
        "filename": "HPM_DT_V20D_IEEE_Access扩展模板.tex",
        "documentclass": "\\documentclass[UTF8]{ctexart}",
        "audience": "IEEE Access 风格扩展论文预排版",
        "required_sections": ["Introduction", "Related Work", "Method", "Results", "Discussion", "Conclusion"]
      },
      {
        "id": "plugin_chinese_thesis_method",
        "name": "中文博士论文章节模板",
        "kind": "thesis_chapter",
        "filename": "HPM_DT_V20D_中文博士论文章节模板.tex",
        "documentclass": "\\documentclass[UTF8]{ctexrep}",
        "audience": "博士论文平台方法与验证章节",
        "required_sections": ["平台总体设计", "可信度验证方法", "论文生产流程", "实验与统计审计", "本章小结"]
      }
    ]
  }
}
